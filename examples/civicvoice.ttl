:CivicVoiceChangeLog rdf:type owl:NamedIndividual ,
                              aidoc:ChangeLog ;
    aidoc:hasChangeRecord :TransitionToModularService ,
                          :AddExperimentTracking ,
                          :AddReproducibleDeployment ,
                          :PlanRegOpsEngineIntegration ;
    rdfs:label "CivicVoice Change Log"@en .

:TransitionToModularService rdf:type owl:NamedIndividual ,
                                     aidoc:ChangeRecord ;
    aidoc:reasonForChange "Transition from standalone clustering component in CivicVoice to a modular MLOps-integrated service." ;
    rdfs:label "Transition to Modular Service"@en .

:AddExperimentTracking rdf:type owl:NamedIndividual ,
                                aidoc:ChangeRecord ;
    aidoc:reasonForChange "Introduction of automated experiment tracking." ;
    rdfs:label "Add Experiment Tracking"@en .

:AddReproducibleDeployment rdf:type owl:NamedIndividual ,
                                    aidoc:ChangeRecord ;
    aidoc:reasonForChange "Introduction of reproducible deployment capabilities." ;
    rdfs:label "Add Reproducible Deployment"@en .

:PlanRegOpsEngineIntegration rdf:type owl:NamedIndividual ,
