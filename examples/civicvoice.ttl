<http://www.semanticweb.org/certain/ontologies/2026/05/civicvoice> rdf:type owl:Ontology ;
    owl:imports <https://w3id.org/aidoc-ap/1.0> ,
                <https://w3id.org/airo/1.0> ,
                <https://w3id.org/vair/1.0> ;
    dcterms:description "AIDOC-AP instantiation for a CivicVoice clustering pipeline with MLOps/RegOps compliance."@en ;
    dcterms:issued "2026-05-28"^^xsd:date ;
    dcterms:title "Clustering Pipeline"@en .

#################################################################
#    Individuals
#################################################################

###  Lifecycle phases
:DevelopmentStage rdf:type owl:NamedIndividual ,
                           vair:Development ;
    aidoc:hasAIActivity :DataExplorationAndValidationActivity ,
                        :SyntheticDataProcessingActivity ,
                        :DataCleaningActivity ,
                        :ModelEngineeringActivity ,
                        :ModelEvaluationActivity ,
                        :ModelVersioningActivity ;
    rdfs:label "Development Stage"@en .

:DeploymentStage rdf:type owl:NamedIndividual ,
                          vair:Deployment ;
    aidoc:hasAIActivity :BuildAndIntegrationTestingActivity ,
                        :SoftwareDeploymentActivity ;
    rdfs:label "Deployment Stage"@en .

:RetirementStage rdf:type owl:NamedIndividual ,
                          vair:Retirement ;
    aidoc:hasAIActivity :DecommissioningActivity ;
    rdfs:label "Retirement Stage"@en .

:OperationStage rdf:type owl:NamedIndividual ,
                         vair:Operation ;
    aidoc:hasAIActivity :DataMonitoringAndLoggingActivity ,
                        :PostMarketMonitoringActivity ,
                        :RiskManagementActivity ;
    rdfs:label "Operation Stage"@en .

:DecommissioningActivity rdf:type owl:NamedIndividual ,
                              aidoc:Decommissioning ;
    dcterms:description "MLOps infrastructure supports controlled rollback and decommissioning for critical issues."@en ;
    rdfs:label "Decommissioning"@en .


###  AI system and agents
:CivicVoiceClusteringPipeline rdf:type owl:NamedIndividual ,
                                       aidoc:AISystem ;
    aidoc:appliesStandard :EU_AI_Act_2024_1689 ,
                          :GDPR_2016_679 ,
                          :MLOpsBestPractices ,
                          :CERTAINAutomatedArchitecturalFramework ;
    aidoc:hasComponent :ClusteringModel ,
                       :SyntheticDataGenerationFramework ;
    aidoc:hasChangeLog :CivicVoiceChangeLog ;
    aidoc:hasDeclarationOfConformity :EUDeclarationOfConformityStatus ;
    aidoc:hasHumanOversight :HumanOversightMechanism ;
    aidoc:hasInterface :MLOpsDashboardInterface ;
    aidoc:hasLifecycleStage :DevelopmentStage ,
                            :DeploymentStage ,
                            :OperationStage ,
                            :RetirementStage ;
    aidoc:hasRisk :BiasInClusteringOutputsRisk ,
                  :PrivacyAndSecurityRisk ,
                  :RegulatoryAlignmentRisk ;
    aidoc:hasSoftwareComponent :DataIngestionModule ,
                               :PreprocessingModule ,
                               :ClusteringEngine ,
                               :OutputGenerationModule ,
                               :MLOpsOrchestrationLayer ;
    aidoc:hasTransparencyMeasure :TransparencyMeasureForUsers ;
    aidoc:intendedPurpose "Automated clustering pipeline that organizes CivicVoice public contributions into thematic groups for downstream analysis." ;
    aidoc:modality "Software-only service integrated into CivicVoice, deployed via the CERTAIN automated architectural framework." ;
    aidoc:version "Extends the earlier CivicVoice backend as a modular MLOps-compatible service with compliance validation and reproducible deployment." ;
    airo:hasAIUser :AuthorizedStakeholders ;
    airo:hasAIUser :Citizens ;
    airo:hasAISubject :Citizens ;
    airo:hasPurpose :ThematicClusteringForPublicDeliberation ;
    aidoc:isProvidedBy :Syntherion ;
    dcterms:description "Modular MLOps clustering pipeline with experiment tracking, reproducible deployment, and compliance validation."@en ;
    rdfs:label "CivicVoice Clustering Pipeline"@en .

:Syntherion rdf:type owl:NamedIndividual ,
                    aidoc:AIProvider ;
    rdfs:label "Syntherion"@en .

:AuthorizedStakeholders rdf:type owl:NamedIndividual ,
                                 airo:AIUser ;
    dcterms:description "Access clustering outputs via the CivicVoice platform and MLOps dashboards."@en ;
    rdfs:label "Authorized Stakeholders"@en .

:Citizens rdf:type owl:NamedIndividual ,
                   dpv:DataSubject ,
                   airo:AISubject ,
                   airo:AIUser ;
    rdfs:label "Citizens"@en .

:ThematicClusteringForPublicDeliberation rdf:type owl:NamedIndividual ,
                                                  airo:Purpose ;
    rdfs:label "Thematic Clustering for Public Deliberation"@en .


###  Risks and governance
:RiskManagementActivity rdf:type owl:NamedIndividual ,
                                 aidoc:AIActivity ;
    dcterms:description "Risks evaluated at each pipeline iteration, at significant changes, and periodically within the MLOps lifecycle."@en ;
    rdfs:label "Risk Management Activity"@en .

:BiasInClusteringOutputsRisk rdf:type owl:NamedIndividual ,
                                      airo:Risk ;
    dcterms:description "Clustering bias may skew viewpoint representation; mitigated through quality evaluation and human review."@en ;
    rdfs:label "Bias in Clustering Outputs Risk"@en .

:PrivacyAndSecurityRisk rdf:type owl:NamedIndividual ,
                                 airo:Risk ;
    dcterms:description "Citizen content processing carries privacy risks; mitigated through access controls and GDPR compliance."@en ;
    rdfs:label "Privacy and Security Risk"@en .

:RegulatoryAlignmentRisk rdf:type owl:NamedIndividual ,
                                  airo:Risk ;
    dcterms:description "Risk of misalignment with EU AI Act requirements; mitigated through automated MLOps compliance checks."@en ;
    rdfs:label "Regulatory Alignment Risk"@en .

:HumanOversightMechanism rdf:type owl:NamedIndividual ,
                                  aidoc:HumanOversightMechanism ;
    dcterms:description "Domain experts review cluster coherence and representativeness; can adjust parameters, merge/split clusters, or exclude irrelevant groupings."@en ;
    rdfs:label "Human Oversight Mechanism"@en .

:TransparencyMeasureForUsers rdf:type owl:NamedIndividual ,
                                      aidoc:TransparencyMeasure ;
    dcterms:description "Users receive information on inputs, outputs, methods, limitations, and quality metrics, including summaries and quality indicators."@en ;
    rdfs:label "Transparency Measure"@en .


###  Standards and conformity
:EU_AI_Act_2024_1689 rdf:type owl:NamedIndividual ,
                              aidoc:Standard ;
    rdfs:label "EU AI Act (Regulation 2024/1689)"@en .

:GDPR_2016_679 rdf:type owl:NamedIndividual ,
                        aidoc:Standard ;
    rdfs:label "GDPR (Regulation 2016/679)"@en .

:MLOpsBestPractices rdf:type owl:NamedIndividual ,
                             aidoc:Standard ;
    rdfs:label "MLOps Best Practices"@en .

:CERTAINAutomatedArchitecturalFramework rdf:type owl:NamedIndividual ,
                                                 aidoc:Standard ;
    rdfs:label "CERTAIN Automated Architectural Framework"@en .

:EUDeclarationOfConformityStatus rdf:type owl:NamedIndividual ,
                                          aidoc:DeclarationOfConformity ;
    dcterms:description "N/A in the questionnaire."@en ;
    rdfs:label "EU Declaration of Conformity Status"@en .


###  Software components and architecture
:DataIngestionModule rdf:type owl:NamedIndividual ,
                              aidoc:SoftwareComponent ;
    aidoc:feedsIntoComponent :PreprocessingModule ;
    rdfs:label "Data Ingestion Module"@en .

:PreprocessingModule rdf:type owl:NamedIndividual ,
                              aidoc:SoftwareComponent ;
    aidoc:feedsIntoComponent :ClusteringEngine ;
    rdfs:label "Preprocessing Module"@en .

:ClusteringEngine rdf:type owl:NamedIndividual ,
                           aidoc:SoftwareComponent ;
    aidoc:feedsIntoComponent :OutputGenerationModule ;
    rdfs:label "Clustering Engine"@en .

:OutputGenerationModule rdf:type owl:NamedIndividual ,
                                 aidoc:SoftwareComponent ;
    rdfs:label "Output Generation Module"@en .

:MLOpsOrchestrationLayer rdf:type owl:NamedIndividual ,
                                  aidoc:SoftwareComponent ;
    aidoc:dependsOn :ExperimentTrackingSubsystem ,
                    :ComplianceValidationSubsystem ;
    rdfs:label "MLOps Orchestration Layer"@en .

:ExperimentTrackingSubsystem rdf:type owl:NamedIndividual ,
                                      aidoc:SoftwareComponent ;
    rdfs:label "Experiment Tracking Subsystem"@en .

:ComplianceValidationSubsystem rdf:type owl:NamedIndividual ,
                                        aidoc:SoftwareComponent ;
    rdfs:label "Compliance Validation Subsystem"@en .

:MLOpsDashboardInterface rdf:type owl:NamedIndividual ,
                                  aidoc:Interface ;
    dcterms:description "Web dashboard for monitoring pipeline executions, experiments, compliance status, and system health, with role-based access control."@en ;
    rdfs:label "MLOps Dashboard Interface"@en .

:LanguageModelEmbeddingMethod rdf:type owl:NamedIndividual ,
                                       aidoc:AIMethod ;
    rdfs:label "Language Model Embedding Method"@en .

:DimensionalityReductionMethod rdf:type owl:NamedIndividual ,
                                        aidoc:AIMethod ;
    rdfs:label "Dimensionality Reduction Method"@en .

:DensityBasedClusteringMethod rdf:type owl:NamedIndividual ,
                                       aidoc:AIMethod ;
    rdfs:label "Density-based Clustering Method"@en .

:ClusteringModel rdf:type owl:NamedIndividual ,
                          aidoc:AIModel ;
    aidoc:hasArchitecture "Modular pipeline-based architecture with ingestion, preprocessing, clustering, and output services orchestrated in MLOps for scalability, reproducibility, automated deployment, and auditing."@en ;
    aidoc:usesAIMethod :LanguageModelEmbeddingMethod ,
                       :DimensionalityReductionMethod ,
                       :DensityBasedClusteringMethod ;
    dcterms:description "Unsupervised clustering using language-model embeddings and inference-time parameter tuning."@en ;
    rdfs:label "Clustering Model"@en .


###  Data, provenance, and quality
:PublicCivicVoiceContributions rdf:type owl:NamedIndividual ,
                                          aidoc:Dataset ;
    aidoc:dataCharacteristic "Citizen opinions, arguments, and proposals from public input processes on the CivicVoice platform." ;
    aidoc:dataCollectionMethod "Collected via public input processes on the CivicVoice platform and then used within synthetic data generation workflows." ;
    aidoc:dataScope "Inputs for thematic clustering in policy-related CivicVoice contexts." ;
    rdfs:label "Public CivicVoice Contributions"@en .

:SyntheticCivicVoiceDataset rdf:type owl:NamedIndividual ,
                                       aidoc:Dataset ;
    aidoc:dataCollectionMethod "Generated through the synthetic data generation framework" ;
    aidoc:dataScope "Privacy-safe surrogate data for clustering inference and evaluation." ;
    dcterms:description "Privacy-safe synthetic surrogates of citizen contributions for GDPR-compliant clustering and evaluation."@en ;
    rdfs:label "Synthetic CivicVoice Dataset"@en .

:SyntheticDataGenerationFramework rdf:type owl:NamedIndividual ,
                                           aidoc:SoftwareComponent ;
    rdfs:label "Synthetic Data Generation Framework"@en .

:DataExplorationAndValidationActivity rdf:type owl:NamedIndividual ,
                                               aidoc:ExplorationAndValidation ;
    aidoc:hasSourceDataset :PublicCivicVoiceContributions ;
    dcterms:description "Contributions reviewed for quality, relevance, and suitability before processing."@en ;
    rdfs:label "Data Exploration and Validation Activity"@en .

:SyntheticDataProcessingActivity rdf:type owl:NamedIndividual ,
                                          aidoc:DataProcessing ;
    aidoc:hasSourceDataset :PublicCivicVoiceContributions ;
    aidoc:producesDataset :SyntheticCivicVoiceDataset ;
    dcterms:description "Transforms CivicVoice contributions into privacy-safe synthetic surrogates for GDPR-compliant downstream use."@en ;
    rdfs:label "Synthetic Data Processing Activity"@en .

:DataCleaningActivity rdf:type owl:NamedIndividual ,
                              aidoc:DataWrangling ;
    aidoc:hasSourceDataset :PublicCivicVoiceContributions ;
    dcterms:description "Content moderation filters spam and off-topic content; data is validated for completeness and relevance."@en ;
    rdfs:label "Data Cleaning Activity"@en .

:DataMonitoringAndLoggingActivity rdf:type owl:NamedIndividual ,
                                           aidoc:DataMonitoringAndLogging ;
    aidoc:storesLogsAt :CentralizedAccessControlledRepositories ;
    dcterms:description "Logs cover ingestion, preprocessing, clustering runs, model parameters, compliance results, execution metadata, and system health."@en ;
    rdfs:label "Data Monitoring and Logging Activity"@en .

:PostMarketMonitoringActivity rdf:type owl:NamedIndividual ,
                                       aidoc:AIActivity ;
    dcterms:description "Tracks execution status, output quality, and compliance; alerts flag anomalies and periodic reviews are performed by authorized personnel."@en ;
    rdfs:label "Post-market Monitoring Activity"@en .

:CentralizedAccessControlledRepositories rdf:type owl:NamedIndividual ,
                                                  aidoc:SoftwareComponent ;
    dcterms:description "Centralized repositories with restricted access for auditing, traceability, and regulatory review."@en ;
    rdfs:label "Centralized Access-Controlled Repositories"@en .


###  Model engineering, evaluation, testing, deployment, and versioning
:ModelEngineeringActivity rdf:type owl:NamedIndividual ,
                                   aidoc:ModelEngineering ;
    dcterms:description "Embeds text via a language model and applies unsupervised clustering; development is iterative with component and integration testing."@en ;
    rdfs:label "Model Engineering Activity"@en .

:ModelEvaluationActivity rdf:type owl:NamedIndividual ,
                                  aidoc:ModelEvaluation ;
    aidoc:hasPerformanceMetric :SilhouetteScoreMetric ,
                               :ClusterCoherenceMetric ,
                               :ClusterSeparationMetric ,
                               :ClusterStabilityMetric ;
    dcterms:description "Combines clustering metrics with expert qualitative review; includes representative datasets and automated regression testing."@en ;
    rdfs:label "Model Evaluation Activity"@en .

:BuildAndIntegrationTestingActivity rdf:type owl:NamedIndividual ,
                                             aidoc:BuildAndIntegrationTesting ;
    dcterms:description "Vulnerability scanning of dependencies and infrastructure; repeated for significant system or environment changes."@en ;
    rdfs:label "Build and Integration Testing Activity"@en .

:SoftwareDeploymentActivity rdf:type owl:NamedIndividual ,
                                     aidoc:Deployment ;
    dcterms:description "Runs on cloud or on-premise containerized servers, integrated into CivicVoice under CERTAIN framework controls."@en ;
    rdfs:label "Software Deployment Activity"@en .

:ModelVersioningActivity rdf:type owl:NamedIndividual ,
                                  aidoc:ModelVersioning ;
    dcterms:description "Versions managed via version control; MLOps tracks component versions per execution with controlled rollout and regression testing."@en ;
    rdfs:label "Model Versioning Activity"@en .

:SilhouetteScoreMetric rdf:type owl:NamedIndividual ,
                                aidoc:PerformanceMetric ;
    rdfs:label "Silhouette Score"@en .

:ClusterCoherenceMetric rdf:type owl:NamedIndividual ,
                                 aidoc:PerformanceMetric ;
    rdfs:label "Cluster Coherence"@en .

:ClusterSeparationMetric rdf:type owl:NamedIndividual ,
                                  aidoc:PerformanceMetric ;
    rdfs:label "Cluster Separation"@en .

:ClusterStabilityMetric rdf:type owl:NamedIndividual ,
                                 aidoc:PerformanceMetric ;
    rdfs:label "Cluster Stability"@en .


