@prefix : <http://www.semanticweb.org/certain/ontologies/2025/10/encom/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <https://w3id.org/airo#> .
@prefix ns2: <https://w3id.org/aidoc-ap#> .
@prefix ns3: <https://w3id.org/dpv#> .
@prefix ns4: <http://www.w3.org/ns/dqv#> .
@prefix ns5: <http://w3id.org/devops-infra/server#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.semanticweb.org/certain/ontologies/2025/10/encom> a owl:Ontology ;
    owl:imports <http://purl.org/cld/freq/>,
        <http://w3id.org/devops-infra/server/1.0.0>,
        <https://w3id.org/aidoc-ap/1.0>,
        <https://w3id.org/airo/1.0>,
        <https://w3id.org/vair/1.0> .

:Basic_Endpoint_Security a owl:NamedIndividual,
        <https://w3id.org/vair#SecurityMeasure> ;
    :isFictional true ;
    ns1:modifiesRiskConcept :Outside_Data_Manipulation .

:Data_Poisoning a owl:NamedIndividual,
        <https://w3id.org/vair#DataPoisoning> ;
    :isFictional true ;
    ns1:isRiskSourceFor :Outside_Data_Manipulation .

:Model_Evaluation a owl:NamedIndividual,
        ns2:ModelEvaluation ;
    ns2:hasPerformanceMetric :Accuracy,
        :Completeness,
        :Consistency,
        :Correctness,
        :Freedom_from_redundancy,
        :Relevance,
        :Timeliness,
        :Uniformity .

:Update_Libraries a owl:NamedIndividual,
        ns1:Change ;
    dcterms:description "keeping the system and the used libraries up to date" ;
    ns1:hasChangedEntity :Encom .

:git-sync_container a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    dcterms:description "Keeps the latest tag on the main branch and the airflow instance in sync" ;
    ns2:requiresHardware :Server_3 ;
    ns2:version "Alpine Linux version 3.21.3" .

:isFictional a owl:DatatypeProperty ;
    rdfs:label "is fictional" ;
    rdfs:range xsd:boolean .

ns2:frequency a owl:AnnotationProperty .

:AI_ISO_Standard a owl:NamedIndividual,
        <https://w3id.org/vair#ISOIEC22989-2022> ;
    :isFictional true .

:Admin_Backend a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    ns2:dependsOn :FastAPI,
        :Python ;
    ns2:requiresHardware :Server_2 .

:Admin_frontend a owl:NamedIndividual,
        ns2:Interface,
        ns2:SoftwareComponent ;
    ns2:dependsOn :NextJS,
        :React,
        :TailwindCSS ;
    ns2:requiresHardware :Server_2 .

:Apache_Airflow a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    ns2:requiresHardware :Server_3 ;
    ns2:version "2.10.5-python3.12" .

:Apache_Airflow_Worker a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    rdfs:comment "scaleable" ;
    ns2:requiresHardware :Server_4 ;
    ns2:version "2.10.5-python3.12" .

:Authentik a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    dcterms:description "Authentication service and identity management" ;
    ns2:requiresHardware :Server_2 ;
    ns2:version "2025.4" .

:Combine_Datasets_Activity a owl:NamedIndividual,
        ns2:DataProcessing ;
    ns2:hasSourceDataset :Energy_Data,
        :Weather_Data ;
    ns2:producesDataset :Combined_Energy_and_Weather_Data .

:Data_Validation a owl:NamedIndividual,
        ns2:DataValidation .

:Database a owl:NamedIndividual,
        ns2:SoftwareComponent .

:Deployment a owl:NamedIndividual,
        <https://w3id.org/vair#Deployment> ;
    ns2:hasAIActivity :Software_Deployment .

:Development_Stage a owl:NamedIndividual,
        <https://w3id.org/vair#Development> ;
    ns2:hasAIActivity :Combine_Datasets_Activity,
        :Data_Point_Quality_Confirmation,
        :EPEX_Data_Acquisition,
        :EnergyDataAcquisition,
        :MLflow_Model_Versioning,
        :Model_Engineering,
        :Software_Development,
        :Software_Versioning,
        :Training_Activity,
        :WeatherDataAcquisition .

:Docker a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    ns2:version "28.0.1, build 068a01e" .

:Docker_Compose a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    ns2:version "v2.33.1" .

:EEGFaktura a owl:NamedIndividual,
        ns3:DataSource ;
    dcterms:description "service which collects energy data of subscribed energy communities" .

:EPEX_Data_Acquisition a owl:NamedIndividual,
        ns2:DataAcquisitionActivity ;
    ns3:hasData :EPEX_spot_AT_exchange_prices .

:EPEX_spot_AT_exchange_prices a owl:NamedIndividual,
        ns2:Dataset ;
    ns3:hasData :aWATTar .

:Encom a owl:NamedIndividual,
        ns2:AISystem ;
    rdfs:label "Energy Community AI" ;
    ns2:appliesStandard :AI_ISO_Standard ;
    ns2:hasChangeLog :ChangeLog ;
    ns2:hasComponent :Encom_AI_Model,
        :Encom_Implementation ;
    ns2:hasIntendedPurpose :IntendedPurpose_1,
        :IntendedPurpose_2,
        :IntendedPurpose_3 ;
    ns2:hasLifecycleStage :Deployment,
        :Development_Stage,
        :Operation ;
    ns2:hasRisk :Outside_Data_Manipulation,
        :Unpermitted_predictions ;
    ns2:hasSoftwareComponent :Admin_Backend,
        :Admin_frontend,
        :Apache_Airflow,
        :Apache_Airflow_Worker,
        :Authentik,
        :Database,
        :Docker,
        :Docker_Compose,
        :Grafana,
        :MLflow,
        :Minio_Bucket,
        :Timescale_DB,
        :traefik ;
    ns2:requiresHardware :Server_1,
        :Server_2,
        :Server_3,
        :Server_4 ;
    ns1:hasModality <https://w3id.org/vair#Service> ;
    ns1:hasPurpose :Predict_energy_consumption_and_generation_data,
        :Predict_optimal_schedules_of_participation_factors_of_a_metering_point,
        :Predict_single_metering_points_or_semantic_groups_of_metering_points ;
    ns1:hasRiskControl :User_Training ;
    ns1:isDeployedBy :Encom_Data_Scientiest ;
    ns1:isDevelopedBy :Encom_Data_Scientiest ;
    ns1:isProvidedBy :Encom_Data_Scientiest ;
    ns3:hasData :Energy_Data .

:Encom_AI_Model a owl:NamedIndividual,
        ns2:AIModel ;
    ns2:usesAIMethod :XGBoost ;
    ns1:hasComponent :Hyperparameters .

:Encom_Implementation a owl:NamedIndividual,
        ns2:SoftwareImplementation ;
    ns2:dependsOn :Pandas,
        :Plotly,
        :Python,
        :matplotlib,
        :optuna,
        :seaborn,
        :xgboost .

:EnergyDataAcquisition a owl:NamedIndividual,
        ns2:DataAcquisitionActivity ;
    ns3:hasData :Energy_Data .

:FastAPI a owl:NamedIndividual,
        ns2:SoftwareDependency ;
    ns2:version "0.116.0" .

:GeoSphere_Austria a owl:NamedIndividual,
        ns3:DataSource .

:Grafana a owl:NamedIndividual,
        ns2:Interface,
        ns2:SoftwareComponent ;
    dcterms:description "Dashboard" ;
    ns2:requiresHardware :Server_2 ;
    ns2:version "12.0.2" .

:Hyperparameters a owl:NamedIndividual,
        ns1:AIComponent ;
    dcterms:description "updated on a monthly basis" ;
    ns1:usesTechnique <https://w3id.org/vair#BayesianOptimisation> .

:IntendedPurpose_1 a ns2:IntendedPurpose ;
    rdfs:label "Predict energy consumption and generation data" .

:IntendedPurpose_2 a ns2:IntendedPurpose ;
    rdfs:label "Predict optimal schedules of participation factors of a metering point" .

:IntendedPurpose_3 a ns2:IntendedPurpose ;
    rdfs:label "Predict single metering points or semantic groups of metering points" .

:MLflow a owl:NamedIndividual,
        ns2:SoftwareComponent .

:MLflow_Model_Versioning a owl:NamedIndividual,
        ns2:ModelVersioning .

:Model_Engineering a owl:NamedIndividual,
        ns2:ModelEngineering ;
    ns2:hasFrequency <http://purl.org/cld/freq/daily> ;
    ns1:hasFrequency :Daily_Training_Frequency .

:Monitoring_an_Logging a owl:NamedIndividual,
        ns2:DataMonitoringAndLogging ;
    dcterms:description "logs are rotated weekly" ;
    ns2:logsActivity :Data_Point_Quality_Confirmation,
        :Data_Validation ;
    ns2:storesLogsAt :Minio_Bucket .

:NextJS a owl:NamedIndividual,
        ns2:SoftwareDependency ;
    ns2:version "15.2.4" .

:Operation a owl:NamedIndividual,
        <https://w3id.org/vair#Operation> ;
    ns2:hasAIActivity :Monitoring_an_Logging .

:Pandas a owl:NamedIndividual,
        ns2:SoftwareDependency .

:Plotly a owl:NamedIndividual,
        ns2:SoftwareDependency .

:Predict_energy_consumption_and_generation_data a owl:NamedIndividual,
        ns1:Purpose .

:Predict_optimal_schedules_of_participation_factors_of_a_metering_point a owl:NamedIndividual,
        ns1:Purpose .

:Predict_single_metering_points_or_semantic_groups_of_metering_points a owl:NamedIndividual,
        ns1:Purpose .

:Predictions a owl:NamedIndividual,
        ns2:Dataset,
        <https://w3id.org/vair#Prediction> ;
    dcterms:description "energy consumption and generation" ;
    ns2:isStoredAt :Minio_Bucket .

:React a owl:NamedIndividual,
        ns2:SoftwareDependency ;
    ns2:version "19.1.0" .

:Software_Deployment a owl:NamedIndividual,
        ns2:Deployment .

:Software_Development a owl:NamedIndividual,
        ns2:SoftwareDevelopment ;
    dcterms:description "Feature branching methodology, reviewed by devs/DS, merged to staging, merged to main, tagged" ;
    ns2:hasResponsibleDeveloper :Encom_Data_Scientiest .

:Software_Versioning a owl:NamedIndividual,
        ns2:SoftwareVersioning ;
    dcterms:description "all pipelines are tracked and versioned on GitHub" .

:TailwindCSS a owl:NamedIndividual,
        ns2:SoftwareDependency ;
    ns2:version "1.0.7" .

:Timescale_DB a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    ns2:requiresHardware :Server_1 ;
    ns2:version "pg17" .

:Training_Activity a owl:NamedIndividual,
        ns2:DataTraining ;
    ns2:hasFrequency <http://purl.org/cld/freq/daily> ;
    ns2:usesTrainingData :Combined_Energy_and_Weather_Data ;
    ns1:hasFrequency :Daily_Training_Frequency .

:Unpermitted_predictions a owl:NamedIndividual,
        ns1:Misuse ;
    dcterms:description "Utilizing energy consumption to predict member behaviour for use in malicious activitie like choosing burglary targets or mapping escape routes." ;
    :isFictional true ;
    ns1:hasConsequence <https://w3id.org/vair#Harm> .

:Updated_dependencies a owl:NamedIndividual,
        ns2:ChangeRecord ;
    dcterms:description "updated software dependencies" ;
    ns2:reasonForChange "outdated software dependencies" ;
    ns2:recordsChange :ChangeLog ;
    ns1:hasStakeholder :Encom_Data_Scientiest .

:User_Training a owl:NamedIndividual,
        <https://w3id.org/vair#UserTraining> ;
    :isFictional true ;
    ns1:modifiesRiskConcept :Outside_Data_Manipulation .

:Version_3.12 a owl:NamedIndividual,
        ns1:Version .

:WeatherDataAcquisition a owl:NamedIndividual,
        ns2:DataAcquisitionActivity ;
    ns3:hasData :Weather_Data .

:XGBoost a owl:NamedIndividual,
        ns2:AIMethod ;
    rdfs:label "Extreme Gradient Boosting" ;
    ns1:producesOutput :Predictions .

:aWATTar a owl:NamedIndividual,
        ns3:DataSource .

:matplotlib a owl:NamedIndividual,
        ns2:SoftwareDependency .

:optuna a owl:NamedIndividual,
        ns2:SoftwareDependency .

:seaborn a owl:NamedIndividual,
        ns2:SoftwareDependency .

:traefik a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    dcterms:description "Reverse proxy" ;
    ns2:requiresHardware :Server_2 ;
    ns2:version "3.2" .

:xgboost a owl:NamedIndividual,
        ns2:SoftwareDependency .

:Accuracy a owl:NamedIndividual,
        ns4:QualityMeasurement,
        ns2:PerformanceMetric .

:ChangeLog a owl:NamedIndividual,
        ns2:ChangeLog ;
    ns2:hasChangeRecord :Updated_dependencies .

:Combined_Energy_and_Weather_Data a owl:NamedIndividual,
        ns2:Dataset ;
    ns2:isStoredAt :Minio_Bucket .

:Completeness a owl:NamedIndividual,
        ns4:QualityMeasurement,
        ns2:PerformanceMetric .

:Consistency a owl:NamedIndividual,
        ns4:QualityMeasurement,
        ns2:PerformanceMetric .

:Correctness a owl:NamedIndividual,
        ns4:QualityMeasurement,
        ns2:PerformanceMetric .

:Daily_Training_Frequency a owl:NamedIndividual .

:Data_Point_Quality_Confirmation a owl:NamedIndividual,
        ns2:DataCleaningProcedure ;
    dcterms:description "Only data points with a confirmed quality (flagged by the grid operator) are used for training the models" .

:Freedom_from_redundancy a owl:NamedIndividual,
        ns4:QualityMeasurement,
        ns2:PerformanceMetric .

:Python a owl:NamedIndividual,
        ns2:SoftwareDependency ;
    rdfs:comment "3.12" ;
    ns1:hasVersion :Version_3.12 .

:Relevance a owl:NamedIndividual,
        ns4:QualityMeasurement,
        ns2:PerformanceMetric .

:Server_4 a ns5:Server,
        owl:NamedIndividual ;
    ns5:cpu "Octa Core CPU with Hyperthreading" ;
    ns5:memory "16.0"^^xsd:float ;
    ns5:numberCPUs 1 ;
    ns5:operatingSystem "Ubuntu Server 24.04 LTS" .

:Timeliness a owl:NamedIndividual,
        ns4:QualityMeasurement,
        ns2:PerformanceMetric .

:Uniformity a owl:NamedIndividual,
        ns4:QualityMeasurement,
        ns2:PerformanceMetric .

:Weather_Data a owl:NamedIndividual,
        ns2:Dataset ;
    dcterms:description "Weather dasta of past month" ;
    ns3:hasDataSource :GeoSphere_Austria .

:Energy_Data a owl:NamedIndividual,
        ns2:Dataset ;
    dcterms:description "readings of metering points, where each reading has a corresponding quality flag" ;
    ns4:hasQualityMeasurement :Accuracy,
        :Completeness,
        :Consistency,
        :Correctness,
        :Freedom_from_redundancy,
        :Relevance,
        :Timeliness,
        :Uniformity ;
    ns3:hasDataSource :EEGFaktura .

:Server_1 a ns5:Server,
        owl:NamedIndividual ;
    ns5:cpu "Octa Core CPU with Hyperthreading" ;
    ns5:memory "16.0"^^xsd:float ;
    ns5:numberCPUs 1 ;
    ns5:operatingSystem "Ubuntu Server 24.04 LTS" .

:Server_3 a ns5:Server,
        owl:NamedIndividual ;
    ns5:cpu "Octa Core CPU with Hyperthreading" ;
    ns5:memory "16.0"^^xsd:float ;
    ns5:numberCPUs 1 ;
    ns5:operatingSystem "Ubuntu Server 24.04 LTS" .

:Minio_Bucket a owl:NamedIndividual,
        ns2:SoftwareComponent ;
    rdfs:label "Minio S3" ;
    dcterms:description "stores log backups" ;
    ns2:requiresHardware :Server_1 ;
    ns2:version "RELEASE.2025-04-03T14-56-28Z" .

:Outside_Data_Manipulation a owl:NamedIndividual,
        ns1:Risk ;
    dcterms:description "Outside manipulation in order to sabotage the system" ;
    :isFictional true ;
    ns1:hasConsequence <https://w3id.org/vair#Harm> .

:Encom_Data_Scientiest a owl:NamedIndividual,
        ns2:AIDeployer,
        ns2:AIProvider,
        ns2:AIResearcher .

:Server_2 a ns5:Server,
        owl:NamedIndividual ;
    ns5:cpu "Octa Core CPU with Hyperthreading" ;
    ns5:memory "16.0"^^xsd:float ;
    ns5:numberCPUs 1 ;
    ns5:operatingSystem "Ubuntu Server 24.04 LTS" .

