    align:confidence "0.75"^^xsd:float ;
    align:rationale "While both concepts relate to validation data within the AI lifecycle, they focus on different aspects. AIDOC describes *the activity* of using data for validation, while dpv-ai focuses specifically on *risks associated with* that validation data. They are connected but not subsuming each other; hence a related match is most appropriate."^^xsd:string ;
    align:relation skos:relatedMatch ;
    align:source aidoc:DataValidation ;
    align:target <https://w3id.org/dpv/ai#ValidationDataRisk> .

align:5f629a2b-5d6d-4c3b-9f91-129043ff63ea a prov:Entity,
