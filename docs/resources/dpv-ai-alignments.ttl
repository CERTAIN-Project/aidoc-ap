    align:confidence "0.85"^^xsd:float ;
    align:rationale "The AIDOC 'Machine Learning Pipeline' describes a *process* encompassing the entire lifecycle of ML activities. The dpv-ai 'MachineLearningModel' is a *component* within that pipeline – specifically, the mathematical construct used for prediction. Therefore, a MachineLearningModel is a narrower concept than a Machine Learning Pipeline."^^xsd:string ;
    align:relation skos:narrowMatch ;
    align:source aidoc:MLPipeline ;
    align:target <https://w3id.org/dpv/ai#MachineLearningModel> .

align:745b2e39-aadc-4b47-b3b5-f2f0f381de43 a prov:Entity,
