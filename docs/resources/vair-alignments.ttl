    prov:wasGeneratedBy align:e58a2db1-5c28-40a2-a8b6-e77aaa929771 ;
    align:confidence "0.85"^^xsd:float ;
    align:rationale "Both concepts relate to data used for machine learning training. The AIDOC concept is more detailed, specifying *what* information the 'Training Data Sheet' contains (methodologies, hyperparameters etc.), while vair#TrainingData focuses on the data itself. They are highly related and could be used interchangeably in many contexts, but aren’t strictly identical due to the level of detail."^^xsd:string ;
    align:relation skos:closeMatch ;
    align:source aidoc:TrainingDataSheet ;
    align:target <https://w3id.org/vair#TrainingData> .

