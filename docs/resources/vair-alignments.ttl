    align:confidence "0.85"^^xsd:float ;
    align:rationale "A 'Machine Learning Library' (vair) is a *component* used within a broader 'Machine Learning Pipeline' (AIDOC). The pipeline encompasses the entire process, while the library represents tools utilized in that process. Thus, vair is narrower than AIDOC."^^xsd:string ;
    align:relation skos:narrowMatch ;
    align:source aidoc:MLPipeline ;
    align:target <https://w3id.org/vair#MachineLearningLibrary> .

