align:a8dc2bea-56e5-4edd-b5e7-32018f122be1 a prov:Entity,
        align:Mapping ;
    prov:wasAttributedTo align:LLMAlignmentBot ;
    prov:wasGeneratedBy align:e58a2db1-5c28-40a2-a8b6-e77aaa929771 ;
    align:confidence "0.85"^^xsd:float ;
    align:rationale "The AIDOC 'Machine Learning Pipeline' represents a *specific instantiation* of the more general 'Machine Learning' process described by vair. A pipeline *is a part of* machine learning; it’s how you *do* machine learning, not what machine learning *is*. The description of the vair concept is broader and defines the core activity, while AIDOC focuses on the implementation."^^xsd:string ;
    align:relation skos:broadMatch ;
    align:source aidoc:MLPipeline ;
    align:target <https://w3id.org/vair#MachineLearning> .

align:a9411c07-f5f4-4bfb-b9ab-14437d7889f2 a prov:Entity,
        align:Mapping ;
    prov:wasAttributedTo align:LLMAlignmentBot ;
    prov:wasGeneratedBy align:e58a2db1-5c28-40a2-a8b6-e77aaa929771 ;
    align:confidence "0.85"^^xsd:float ;
    align:rationale "Both concepts relate to the environment for machine learning activities. 'Machine Learning Pipeline' (AIDOC) describes *how* ML is done – the process. 'Machine Learning Platform' (vair) describes *where* it’s done - the infrastructure. They are closely related and often co-occurring, but not identical; a pipeline utilizes a platform."^^xsd:string ;
    align:relation skos:closeMatch ;
    align:source aidoc:MLPipeline ;
    align:target <https://w3id.org/vair#MachineLearningPlatform> .

