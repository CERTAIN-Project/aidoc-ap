align:370532b0-0a88-4ee3-9d30-15b3135579f1 a prov:Entity,
        align:Mapping ;
    prov:wasAttributedTo align:LLMAlignmentBot ;
    prov:wasGeneratedBy align:e58a2db1-5c28-40a2-a8b6-e77aaa929771 ;
    align:confidence "0.85"^^xsd:float ;
    align:rationale "Both concepts relate to ensuring an AI system functions correctly and meets expectations. However, the AIDOC concept specifically focuses on *data* validation for model training/tuning (preventing overfitting/underfitting), while the vair concept is a broader assessment of overall system performance against requirements. They overlap significantly but aren't fully interchangeable; data validation is *a type of* validation."^^xsd:string ;
    align:relation skos:closeMatch ;
    align:source aidoc:DataValidation ;
    align:target <https://w3id.org/vair#Validation> .

align:4c7528bc-2059-4f44-b8c9-a0f95f063c13 a prov:Entity,
        align:Mapping ;
    prov:wasAttributedTo align:LLMAlignmentBot ;
    prov:wasGeneratedBy align:e58a2db1-5c28-40a2-a8b6-e77aaa929771 ;
    align:confidence "0.95"^^xsd:float ;
    align:rationale "Both concepts define data used for training machine learning models. The descriptions are nearly identical and the lexical similarity is high. While 'Data Training' frames it as an *activity*, 'TrainingData' focuses on the *data* itself – a subtle difference not significant enough to warrant anything less than exact match at this conceptual level."^^xsd:string ;
    align:relation skos:exactMatch ;
    align:source aidoc:DataTraining ;
    align:target <https://w3id.org/vair#TrainingData> .

align:769a47eb-95cb-479b-a860-7955d0e9d9d2 a prov:Entity,
