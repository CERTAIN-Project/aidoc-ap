    align:rationale "Both concepts share the same label and a highly similar description defining 'Transparency Measure'. The presence of a URI in vair suggests it's a formally defined concept, but the descriptions are functionally equivalent for interoperability purposes at this level."^^xsd:string ;
    align:relation skos:exactMatch ;
    align:source aidoc:TransparencyMeasure ;
    align:target <https://w3id.org/vair#TransparencyMeasure> .

align:7c024c9d-78c7-4816-ad18-26003859298a a prov:Entity,
