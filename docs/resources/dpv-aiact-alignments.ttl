align:16b5e58b-ff52-409c-ae86-1dcc6c5a4a58 a prov:Entity,
        align:Mapping ;
    prov:wasAttributedTo align:LLMAlignmentBot ;
    prov:wasGeneratedBy align:a055f89c-234f-4b4a-b6ff-23d23067eb57 ;
    align:confidence "0.85"^^xsd:float ;
    align:rationale "The AIDOC concept defines *what* an AI System is – a broad definition encompassing its capabilities and operation. The dpv-aiact concept (AISystemPerformance) focuses on *one aspect* of an AI system - its ability to achieve its intended purpose. Therefore, AISystemPerformance is a specific characteristic *of* an AI System, making it a narrower concept."^^xsd:string ;
    align:relation skos:narrowMatch ;
    align:source aidoc:AISystem ;
    align:target <https://w3id.org/dpv/legal/eu/aiact#AISystemPerformance> .

