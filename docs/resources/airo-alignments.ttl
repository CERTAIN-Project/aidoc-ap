    align:confidence "0.85"^^xsd:float ;
    align:rationale "The 'airo' concept of Documentation is very general. The 'AIDOC' concept 'Visual Documentation' *is a type of* documentation, specifically focusing on visual elements related to AI systems and referencing a specific annex. Therefore, 'Documentation' broadly covers 'Visual Documentation'."^^xsd:string ;
    align:relation skos:broadMatch ;
    align:source aidoc:VisualDocumentation ;
    align:target <https://w3id.org/airo#Documentation> .

