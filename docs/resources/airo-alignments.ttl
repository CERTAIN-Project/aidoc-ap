    align:confidence "0.85"^^xsd:float ;
    align:rationale "Both concepts define the abilities of an AI system. While 'AI System Capability' (AIDOC) specifies *types* of processing, 'AI Capability' (airo) focuses on enabling a system’s purpose. They are highly related and could be used interchangeably in many contexts, but aren't strictly identical due to the differing emphasis."^^xsd:string ;
    align:relation skos:closeMatch ;
    align:source aidoc:AISystemCapability ;
    align:target <https://w3id.org/airo#AICapability> .

