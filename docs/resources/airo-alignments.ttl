    align:confidence "0.85"^^xsd:float ;
    align:rationale "Both concepts refer to the manipulation of data to create a modified dataset. While 'Data Processing' explicitly mentions preprocessing and resulting in *a different* dataset, 'Processing' is more general. They are highly similar but not identical; interchangeability would depend on context."^^xsd:string ;
    align:relation skos:closeMatch ;
    align:source aidoc:DataProcessing ;
    align:target <https://w3id.org/dpv#Processing> .

